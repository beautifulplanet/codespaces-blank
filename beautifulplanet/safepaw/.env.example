# ============================================
# SafePaw — Secure OpenClaw Deployer
# ============================================
# COPY this file to .env and fill in values:
#   cp .env.example .env
#
# NEVER commit the actual .env file.
# This .env.example is the ONLY env file that should be in Git.
# ============================================

# ── Infrastructure ─────────────────────────

# Redis (internal state + rate limiter)
REDIS_PASSWORD=CHANGE_ME_generate_a_random_password

# PostgreSQL (config & state storage)
POSTGRES_USER=safepaw
POSTGRES_PASSWORD=CHANGE_ME_generate_a_random_password
POSTGRES_DB=safepaw

# ── Wizard (Setup UI on :3000) ─────────────

# Leave empty to auto-generate on first launch (printed to stdout once)
# WIZARD_ADMIN_PASSWORD=

# Optional: base32 TOTP secret for MFA. When set, login requires password + 6-digit TOTP code.
# Generate with any authenticator app or: openssl rand -base64 20 | openssl base32
# WIZARD_TOTP_SECRET=

# Set to true when serving over HTTPS to set Secure flag on cookies
# SECURE_COOKIES=false

# ── Gateway (Security Proxy on :8080) ──────

# Rate limiting (requests per window per IP)
# RATE_LIMIT=60
# RATE_LIMIT_WINDOW_SEC=60

# Structured logging (set to "json" for SIEM/ELK/Datadog)
# LOG_FORMAT=text

# Authentication for API access (ENABLED by default in Docker Compose)
# Generate a secret: openssl rand -base64 48
# Set AUTH_ENABLED=false ONLY for local development
AUTH_ENABLED=true
AUTH_SECRET=CHANGE_ME_run_openssl_rand_base64_48
# AUTH_DEFAULT_TTL_HOURS=24
# AUTH_MAX_TTL_HOURS=168

# TLS termination (production)
# Generate self-signed certs for dev:
#   openssl req -x509 -newkey rsa:4096 -keyout tls.key -out tls.crt -days 365 -nodes
TLS_ENABLED=false
# TLS_CERT_FILE=/certs/tls.crt
# TLS_KEY_FILE=/certs/tls.key
# TLS_PORT=8443

# ── OpenClaw (AI Assistant — internal) ─────

# Pin OpenClaw version at image build (default: latest). Set e.g. OPENCLAW_VERSION=1.2.3 for reproducibility.
# OPENCLAW_VERSION=latest

# LLM Providers (at least one required)
# ANTHROPIC_API_KEY=sk-ant-xxxxxx
# OPENAI_API_KEY=sk-xxxxxx

# Channel Tokens (configure via Wizard UI or set here)
# DISCORD_BOT_TOKEN=
# TELEGRAM_BOT_TOKEN=
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=
# SIGNAL_CLI_PATH=
