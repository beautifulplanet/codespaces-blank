# ============================================
# NOPEnclaw Local Development Environment
# ============================================
# COPY this file to .env and fill in values:
#   cp .env.example .env
#
# NEVER commit the actual .env file.
# This .env.example is the ONLY env file that should be in Git.
# ============================================

# Redis
REDIS_PASSWORD=CHANGE_ME_generate_a_random_password

# PostgreSQL
POSTGRES_USER=nopenclaw
POSTGRES_PASSWORD=CHANGE_ME_generate_a_random_password
POSTGRES_DB=nopenclaw

# Gateway
GATEWAY_PORT=8080
REDIS_INBOUND_STREAM=nopenclaw_inbound
REDIS_OUTBOUND_STREAM=nopenclaw_outbound
# ALLOWED_ORIGINS=https://example.com,https://app.example.com

# Authentication
# Generate a secret: openssl rand -base64 48
# AUTH_SECRET=your-secret-here-at-least-32-bytes
AUTH_ENABLED=false
# AUTH_DEFAULT_TTL_HOURS=24
# AUTH_MAX_TTL_HOURS=168

# TLS (Production)
# Generate self-signed certs for dev: openssl req -x509 -newkey rsa:4096 -keyout tls.key -out tls.crt -days 365 -nodes
TLS_ENABLED=false
# TLS_CERT_FILE=/certs/tls.crt
# TLS_KEY_FILE=/certs/tls.key
# TLS_PORT=8443

# Router
# ROUTER_WORKER_COUNT=4
# ROUTER_BATCH_SIZE=10
# CONSUMER_GROUP=nopenclaw_routers
# MAX_MESSAGE_SIZE=65536
# MAX_OUTBOUND_SIZE=65536
# MAX_RETRIES=3
# ACK_TIMEOUT_SEC=30
