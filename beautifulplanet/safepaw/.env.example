# ============================================
# NOPEnclaw Local Development Environment
# ============================================
# COPY this file to .env and fill in values:
#   cp .env.example .env
#
# NEVER commit the actual .env file.
# This .env.example is the ONLY env file that should be in Git.
# ============================================

# Redis
REDIS_PASSWORD=CHANGE_ME_generate_a_random_password

# PostgreSQL
POSTGRES_USER=nopenclaw
POSTGRES_PASSWORD=CHANGE_ME_generate_a_random_password
POSTGRES_DB=nopenclaw

# Gateway
GATEWAY_PORT=8080
REDIS_INBOUND_STREAM=nopenclaw_inbound
REDIS_OUTBOUND_STREAM=nopenclaw_outbound
# ALLOWED_ORIGINS=https://example.com,https://app.example.com
